root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.py]
indent_size = 4

[*.{js,jsx,ts,tsx,mjs,json,jsonc,css,html,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

