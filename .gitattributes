# Auto detect text files and perform LF normalization
* text=auto

# Explicit text file types — always normalize to LF on commit
*.md text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
*.txt text eol=lf
*.svg text eol=lf
*.csv text eol=lf

# Binary files — don't normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
*.sqlite binary
*.excalidraw binary
*.woff binary
*.woff2 binary

# Python scripts
*.py text eol=lf diff=python

