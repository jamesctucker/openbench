#!/usr/bin/env bash
# opencode-sandbox — safety wrapper for OpenCode
#
# Modes:
#   lite (default) — git checkpoint before launch, diff review on exit
#   full           — Apple sandbox-exec + git checkpoint + diff review
#
# Usage:
#   opencode-sandbox [lite|full] [-- opencode-args...]
set -euo pipefail

WORKSPACE="$(cd "$(dirname "$0")/../.." && pwd)"
MODE="${1:-lite}"
[[ "$MODE" == "lite" || "$MODE" == "full" ]] || { echo "Usage: opencode-sandbox [lite|full]"; exit 1; }
shift 2>/dev/null || true

cd "$WORKSPACE"

if ! command -v opencode >/dev/null 2>&1; then
  echo "Error: 'opencode' not found on PATH. Install or add to PATH first." >&2
  exit 1
fi

pii_scan() {
if [ -f "$WORKSPACE/scripts/sandbox/pii-scan" ]; then
     echo "=== PII Scan ==="
     if ! bash "$WORKSPACE/scripts/sandbox/pii-scan" --diff "$1"; then
      echo ""
      echo "WARNING: PII scan found potential secrets in the diff."
      echo "Review the items above carefully before accepting changes."
    else
      echo "PII scan clean."
    fi
  fi
}

review_changes() {
  local START_HASH="$1"
  echo ""
  echo "=== Sandbox Review ==="
  if git diff --stat "$START_HASH" HEAD --exit-code >/dev/null 2>&1; then
    echo "No changes detected since launch."
    return 0
  fi

  echo ""
  echo "Changes made in this session:"
  git diff --stat "$START_HASH" HEAD
  echo ""

  pii_scan "$START_HASH"
  echo ""

  echo "What would you like to do?"
  echo "  [a] Accept all changes"
  echo "  [r] Revert all changes"
  echo "  [d] Show full diff"
  echo "  [i] Inspect interactively"
  echo -n "Choice (a/r/d/i): "
  read -r choice

  case "$choice" in
    a|A)
      echo "Changes accepted. Checkpoint commit preserved in git log."
      ;;
    r|R)
      git reset --hard "$START_HASH"
      echo "All changes reverted to checkpoint."
      ;;
    d|D)
      git diff "$START_HASH" HEAD | cat
      echo ""
      echo -n "Accept these changes? (Y/n): "
      read -r confirm
      if [[ "$confirm" == "n" || "$confirm" == "N" ]]; then
        git reset --hard "$START_HASH"
        echo "Reverted."
      else
        echo "Accepted."
      fi
      ;;
    i|I)
      echo "=== Inspect by file ==="
      local files
      while IFS= read -r file; do
        echo ""
        echo "=== $file ==="
        git diff "$START_HASH" HEAD -- "$file" | cat
        echo ""
        echo -n "Keep this change? (Y/n): "
        read -r keep
        if [[ "$keep" == "n" || "$keep" == "N" ]]; then
          git checkout "$START_HASH" -- "$file"
          echo "Reverted $file"
        fi
      done < <(git diff --name-only "$START_HASH" HEAD)
      echo ""
      echo "Interactive inspection complete. Remaining changes accepted."
      ;;
    *)
      echo "No action taken. Run 'git diff $START_HASH HEAD' to review manually."
      ;;
  esac
}

# --- lite mode ---
if [[ "$MODE" == "lite" ]]; then
  START_HASH=$(git rev-parse HEAD)
  if git diff --cached --quiet 2>/dev/null && git diff --quiet 2>/dev/null; then
    echo "(no uncommitted changes to checkpoint)"
  else
    git add -A && git commit -m "sandbox-checkpoint-$(date +%s)" || { echo "Error: checkpoint commit failed" >&2; exit 1; }
  fi

  opencode "$@"

  review_changes "$START_HASH"
  exit 0
fi

# --- full mode ---
if [[ "$MODE" == "full" ]]; then
  PROFILE=$(mktemp /tmp/opencode-sandbox.XXXXXX.sb)

  cat > "$PROFILE" <<SBEOF
(version 1)

;; Block everything by default
(deny default)

;; === NETWORK ===
(allow network-outbound)
(allow network-inbound (local ip "127.0.0.1"))

;; === WORKSPACE (read + write) ===
(allow file-read* (subpath "$WORKSPACE"))
(allow file-write* (subpath "$WORKSPACE"))

;; === TEMP ===
(allow file-read* (subpath "/tmp"))
(allow file-write* (subpath "/tmp"))
(allow file-read* (subpath "/private/tmp"))
(allow file-write* (subpath "/private/tmp"))

;; === SYSTEM BINARIES ===
(allow file-read* (subpath "/bin"))
(allow file-read* (subpath "/sbin"))
(allow file-read* (subpath "/usr/bin"))
(allow file-read* (subpath "/usr/sbin"))
(allow file-read* (subpath "/usr/local/bin"))
(allow file-read* (subpath "/opt/homebrew/bin"))
(allow file-read* (subpath "/opt/homebrew/sbin"))
(allow file-read* (subpath "/System/Cryptexes/App/usr/bin"))

;; === SYSTEM LIBRARIES ===
(allow file-read* (subpath "/usr/lib"))
(allow file-read* (subpath "/System/Library"))
(allow file-read* (subpath "/usr/share"))

;; === OPENCODE CONFIG (needed for normal operation) ===
(allow file-read* (subpath "$HOME/.opencode"))

;; === DENY SENSITIVE PATHS (explicit block overrides) ===
(deny file-read* (subpath "$HOME/.ssh"))
(deny file-read* (subpath "$HOME/.aws"))
(deny file-read* (subpath "$HOME/.gnupg"))
(deny file-read* (subpath "$HOME/.config"))
(deny file-read* (subpath "$HOME/Library/Keychains"))
(deny file-read* (subpath "$HOME/.git-credentials"))
(deny file-read* (subpath "$HOME/.npmrc"))
(deny file-read* (subpath "$HOME/.env"))
(deny file-read* (subpath "/etc/ssh"))

;; === PROCESS ===
(allow process-fork)
(allow process-exec)

;; === MACH SERVICES (needed by macOS binaries) ===
(allow mach-lookup (global-name "com.apple.system.notification_center"))
(allow mach-lookup (global-name "com.apple.coreservices.launchservicesd"))
(allow mach-lookup (global-name "com.apple.system.logger"))
(allow mach-lookup (global-name "com.apple.system.opendirectoryd.libinfo"))
SBEOF

  START_HASH=$(git rev-parse HEAD)
  if git diff --cached --quiet 2>/dev/null && git diff --quiet 2>/dev/null; then
    echo "(no uncommitted changes to checkpoint)"
  else
    git add -A && git commit -m "sandbox-checkpoint-$(date +%s)" || { echo "Error: checkpoint commit failed" >&2; exit 1; }
  fi

  echo "Warning: sandbox-exec is deprecated on modern macOS. Profiles may not work as expected." >&2
  sandbox-exec -f "$PROFILE" opencode "$@"

  rm -f "$PROFILE"

  review_changes "$START_HASH"
  exit 0
fi
