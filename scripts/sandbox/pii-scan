#!/usr/bin/env bash
# pii-scan — scan staged git diffs for potential secrets/PII
#
# Patterns checked:
#   - API keys (common prefixes: sk-, pk-, api_key, etc.)
#   - AWS access keys (AKIA...)
#   - Private keys (BEGIN RSA/OPENSSH/EC PRIVATE KEY)
#   - Generic high-entropy tokens (base64-ish strings > 32 chars)
#   - Common credential filenames (.env, credentials.json, etc.)
#
# Usage:
#   scripts/sandbox/pii-scan              # scan staged changes
#   scripts/sandbox/pii-scan --all         # scan entire repo
#   scripts/sandbox/pii-scan --diff HEAD~1 # scan diff against specific ref
set -euo pipefail

MODE="${1:---staged}"
WORKSPACE="$(cd "$(dirname "$0")/../.." && pwd)"

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

found=0

check_diff() {
    local diff_output="$1"
    local context="$2"

    # AWS access key IDs
    if printf '%s' "$diff_output" | grep -qE '(^|\s|=|:|")AKIA[0-9A-Z]{16}($|\s|"|'"'"')'; then
        echo -e "${RED}[PII] AWS access key ID detected${NC} ($context)"
        found=1
    fi

    # Generic API key patterns
    if printf '%s' "$diff_output" | grep -qE '(^|\s|=|:|")(sk|pk|api[_-]?key|api[_-]?secret|secret[_-]?key|access[_-]?key|auth[_-]?token)["\s]*[:=]["\s]*[A-Za-z0-9_\-]{20,}'; then
        echo -e "${RED}[PII] Potential API key/secret detected${NC} ($context)"
        found=1
    fi

    # Private keys
    if printf '%s' "$diff_output" | grep -qE 'BEGIN\s+(RSA|OPENSSH|EC|DSA|PGP)\s+PRIVATE\s+KEY'; then
        echo -e "${RED}[PII] Private key detected${NC} ($context)"
        found=1
    fi

    # OpenAI / common API key format (sk-...)
    if printf '%s' "$diff_output" | grep -qE '(^|\s|=|:|")sk-[A-Za-z0-9]{20,}'; then
        echo -e "${RED}[PII] OpenAI-style API key detected (sk-...)${NC} ($context)"
        found=1
    fi

    # GitHub tokens
    if printf '%s' "$diff_output" | grep -qE '(^|\s|=|:|")gh[pous]_[A-Za-z0-9]{20,}'; then
        echo -e "${RED}[PII] GitHub token detected${NC} ($context)"
        found=1
    fi

    # High-entropy base64-like strings (likely tokens/secrets)
    # Only scan added lines (^+) to reduce false positives from existing content.
    # NOTE: This pattern can still false-positive on base64-encoded images,
    # long hashes, and encoded data. Review YELLOW findings carefully.
    if printf '%s' "$diff_output" | grep -E '^\+' | grep -qE '(^|\s|=|:|")[A-Za-z0-9+/=]{40,}($|\s|")'; then
        echo -e "${YELLOW}[PII] High-entropy string detected (possible secret)${NC} ($context)"
        found=1
    fi

    # Common credential files being added
    if printf '%s' "$diff_output" | grep -qE '^\+\+\+ b/.*\.(env|pem|key|pfx|p12|jks|keystore|credentials)(\s|$)'; then
        echo -e "${RED}[PII] Credential file being added${NC} ($context)"
        found=1
    fi
}

case "$MODE" in
    --staged)
        cd "$WORKSPACE"
        if git rev-parse --git-dir >/dev/null 2>&1; then
            DIFF=$(git diff --cached 2>/dev/null || true)
            if [ -n "$DIFF" ]; then
                check_diff "$DIFF" "staged changes"
            fi
            # Also check new files being added
            NEW_FILES=$(git diff --cached --name-only --diff-filter=A 2>/dev/null || true)
            if [ -n "$NEW_FILES" ]; then
                check_diff "$NEW_FILES" "new files"
            fi
        fi
        ;;
    --all)
        cd "$WORKSPACE"
        check_diff "$(git diff HEAD 2>/dev/null || true)" "entire repo (staged+unstaged)"
        # Scan tracked file contents in batches to avoid argument-length / memory limits
        while IFS= read -r -d '' file; do
            check_diff "$(cat "$file" 2>/dev/null || true)" "file: $file"
        done < <(git ls-files -z)
        ;;
    --diff)
        if [ $# -lt 2 ]; then
            echo "Usage: pii-scan --diff <ref>"
            exit 1
        fi
        cd "$WORKSPACE"
        check_diff "$(git diff "$2" HEAD 2>/dev/null || true)" "diff $2..HEAD"
        ;;
    *)
        echo "Usage: pii-scan [--staged|--all|--diff <ref>]"
        exit 1
        ;;
esac

if [ "$found" -eq 1 ]; then
    echo ""
    echo "PII scan found potential secrets. Review the items above."
    echo "If these are false positives, you can bypass with:"
    echo "  git commit --no-verify  (skips pre-commit hook)"
    exit 1
fi

exit 0
